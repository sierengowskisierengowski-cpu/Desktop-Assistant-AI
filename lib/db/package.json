{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "push": "AXIOM_DB_PATH=/home/runner/workspace/axiom.db drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "AXIOM_DB_PATH=/home/runner/workspace/axiom.db drizzle-kit push --force --config ./drizzle.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10"
  }
}
