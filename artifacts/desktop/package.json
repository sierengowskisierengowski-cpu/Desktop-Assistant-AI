{
  "name": "@workspace/desktop",
  "version": "1.0.0",
  "description": "AXIOM — AI-powered desktop assistant for file management, task scheduling, and intelligent automation",
  "author": {
    "name": "Joseph Sierengowski",
    "email": "joseph@axiomapp.dev"
  },
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "electron:compile": "node electron/build.mjs",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite --config vite.config.ts\" \"wait-on http://localhost:21098 && NODE_ENV=development electron .\"",
    "electron:build": "pnpm build && pnpm electron:compile",
    "electron:pack": "pnpm electron:build && electron-builder --config electron-builder.config.cjs",
    "electron:pack:mac": "pnpm electron:build && electron-builder --config electron-builder.config.cjs --mac",
    "electron:pack:win": "pnpm electron:build && electron-builder --config electron-builder.config.cjs --win",
    "electron:pack:linux": "pnpm electron:build && electron-builder --config electron-builder.config.cjs --linux"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.3",
    "@hookform/resolvers": "^3.10.0",
